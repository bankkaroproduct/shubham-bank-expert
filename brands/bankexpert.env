# BankExpert Brand Configuration
# Deploy: copy to .env.local and fill in PARTNER_* secrets

NEXT_PUBLIC_BRAND_NAME=BankExpert
NEXT_PUBLIC_BRAND_LOGO=/bankexpert-logo.png
NEXT_PUBLIC_BRAND_FAVICON=/bankexpert-logo.png
NEXT_PUBLIC_PRIMARY_COLOR=#004E92
NEXT_PUBLIC_SECONDARY_COLOR=#F5F5F5
NEXT_PUBLIC_ACCENT_COLOR=#FFFFFF

# ============================================
# PARTNER API (CRITICAL FOR ATTRIBUTION)
# ============================================
PARTNER_API_KEY=YOUR_BANKEXPERT_API_KEY_HERE
PARTNER_TOKEN_URL=https://platform.bankkaro.com/partner/token
PARTNER_BASE_URL=https://platform.bankkaro.com/partner
NEXT_PUBLIC_APP_URL=https://bankexpert.bankkaro.com
