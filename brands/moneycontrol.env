# MoneyControl Brand Configuration
# Copy these values to Vercel Environment Variables

VITE_BRAND_NAME=MoneyControl Cards
VITE_BRAND_TAGLINE=Find Your Perfect Credit Card
VITE_BRAND_LOGO=/moneycontrol-logo.png
VITE_BRAND_FAVICON=/favicon.png
VITE_BRAND_EMAIL=support@moneycontrol.com

# MoneyControl Green
VITE_PRIMARY_HUE=145
VITE_PRIMARY_SAT=100%
VITE_PRIMARY_LIGHT=33%

# Blue Secondary
VITE_SECONDARY_HUE=211
VITE_SECONDARY_SAT=100%
VITE_SECONDARY_LIGHT=40%

# ============================================
# PARTNER API (CRITICAL FOR ATTRIBUTION)
# ============================================
VITE_PARTNER_API_KEY=YOUR_MONEYCONTROL_API_KEY_HERE
VITE_PARTNER_TOKEN_URL=https://uat-platform.bankkaro.com/partner/token
VITE_PARTNER_BASE_URL=https://uat-platform.bankkaro.com/partner
