# Sample Partner Brand Configuration
# Copy and modify for new partners

VITE_BRAND_NAME=Partner Cards
VITE_BRAND_TAGLINE=Find Your Perfect Credit Card
VITE_BRAND_LOGO=/logo.png
VITE_BRAND_FAVICON=/favicon.png
VITE_BRAND_EMAIL=support@partner.com

# Blue Primary (change HUE for different colors)
# Green=145, Blue=211, Purple=270, Orange=25, Teal=175
VITE_PRIMARY_HUE=211
VITE_PRIMARY_SAT=100%
VITE_PRIMARY_LIGHT=40%

# Secondary Color
VITE_SECONDARY_HUE=270
VITE_SECONDARY_SAT=70%
VITE_SECONDARY_LIGHT=45%

# ============================================
# PARTNER API (CRITICAL FOR ATTRIBUTION)
# ============================================
# Each partner MUST have unique API key for revenue tracking
VITE_PARTNER_API_KEY=YOUR_UNIQUE_PARTNER_API_KEY_HERE
VITE_PARTNER_TOKEN_URL=https://uat-platform.bankkaro.com/partner/token
VITE_PARTNER_BASE_URL=https://uat-platform.bankkaro.com/partner
